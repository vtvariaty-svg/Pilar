rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    match /leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'phone', 'serviceType', 'source', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.source == 'site'
        && request.resource.data.status == 'novo'
        && request.resource.data.serviceType in [
             'Construção do zero',
             'Reforma completa',
             'Ampliação',
             'Banheiro/cozinha',
             'Acabamento',
             'Telhado',
             'Área externa',
             'Outro'
           ];
      allow read: if isAdmin();
      allow update: if
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'internalNotes', 'updatedAt'])
        && (
          !request.resource.data.keys().hasAny(['status'])
          || request.resource.data.status in [
               'novo', 'em_atendimento', 'visita_agendada',
               'proposta_enviada', 'fechado', 'perdido'
             ]
        );
      allow delete: if isAdmin();
    }

    match /quoteEstimates/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['client', 'serviceType', 'inputs', 'calculation', 'status', 'source', 'createdAt', 'updatedAt'])
        && request.resource.data.status == 'estimativa_criada'
        && request.resource.data.source == 'calculator';
      allow read, update, delete: if isAdmin();
    }

    match /appointments/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['clientName', 'phone', 'serviceType', 'date', 'startTime', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.status == 'solicitado';
      allow read, update, delete: if isAdmin();
    }

    match /pricingSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /serviceCatalog/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /platformSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /portfolio/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
