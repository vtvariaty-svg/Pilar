rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapSuperAdmin() {
      return signedIn() && request.auth.token.email == 'vtvariaty@gmail.com';
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.active == true;
    }

    function isSuperAdmin() {
      return isAdmin()
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isPlatformAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'platform_admin';
    }

    function tenantRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role;
    }

    function isTenantMember(tenantId) {
      return signedIn()
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function isTenantStaff(tenantId) {
      return isPlatformAdmin()
        || (isTenantMember(tenantId) && tenantRole(tenantId) in ['owner', 'admin', 'operator'])
        || isAdmin();
    }

    // ── Global collections ─────────────────────────────────────────────

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isPlatformAdmin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'phone', 'updatedAt']);
      allow delete: if isSuperAdmin() || isPlatformAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if
        (isBootstrapSuperAdmin() && request.auth.uid == uid && request.resource.data.role == 'super_admin')
        || (isSuperAdmin() && request.resource.data.role in ['admin', 'super_admin']);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /adminInvites/{inviteId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || isSuperAdmin();
    }

    // ── Tenant subcollections ──────────────────────────────────────────

    match /tenants/{tenantId}/members/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isTenantStaff(tenantId) || isPlatformAdmin());
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == 'customer';
      allow update, delete: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/customers/{uid} {
      allow read: if (signedIn() && request.auth.uid == uid) || isTenantStaff(tenantId) || isPlatformAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if (signedIn() && request.auth.uid == uid) || isTenantStaff(tenantId);
      allow delete: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'phone', 'serviceType', 'source', 'status', 'tenantId', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string && request.resource.data.name.size() > 0
        && request.resource.data.phone is string && request.resource.data.phone.size() > 0
        && request.resource.data.status == 'novo'
        && request.resource.data.source in ['site', 'calculator', 'admin'];
      allow read: if isTenantStaff(tenantId) || isPlatformAdmin()
        || (signedIn() && resource.data.customerUid == request.auth.uid);
      allow update: if isTenantStaff(tenantId) || isPlatformAdmin();
      allow delete: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/quoteEstimates/{quoteId} {
      allow create: if
        request.resource.data.keys().hasAll(['client', 'serviceType', 'inputs', 'calculation', 'status', 'source', 'tenantId', 'createdAt', 'updatedAt'])
        && request.resource.data.status == 'estimativa_criada'
        && request.resource.data.source == 'calculator';
      allow read: if isTenantStaff(tenantId) || isPlatformAdmin()
        || (signedIn() && resource.data.customerUid == request.auth.uid);
      allow update: if isTenantStaff(tenantId) || isPlatformAdmin();
      allow delete: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/appointments/{apptId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['clientName', 'phone', 'serviceType', 'date', 'startTime', 'status', 'tenantId', 'createdAt', 'updatedAt'])
        && request.resource.data.status == 'solicitado';
      allow read: if isTenantStaff(tenantId) || isPlatformAdmin()
        || (signedIn() && resource.data.customerUid == request.auth.uid);
      allow update: if isTenantStaff(tenantId) || isPlatformAdmin();
      allow delete: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/pricingSettings/{id} {
      allow read: if true;
      allow write: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/serviceCatalog/{id} {
      allow read: if true;
      allow write: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/settings/{id} {
      allow read: if true;
      allow write: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    match /tenants/{tenantId}/portfolio/{id} {
      allow read: if true;
      allow write: if isTenantStaff(tenantId) || isPlatformAdmin();
    }

    // ── Legacy collections (backward compat) ──────────────────────────

    match /leads/{leadId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'phone', 'serviceType', 'source', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string && request.resource.data.name.size() > 0
        && request.resource.data.phone is string && request.resource.data.phone.size() > 0
        && request.resource.data.source == 'site'
        && request.resource.data.status == 'novo';
      allow read: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
      allow update: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
      allow delete: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /quoteEstimates/{id} {
      allow read: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /appointments/{id} {
      allow read: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /pricingSettings/{id} {
      allow read: if true;
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /serviceCatalog/{id} {
      allow read: if true;
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /platformSettings/{id} {
      allow read: if true;
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }

    match /portfolio/{id} {
      allow read: if true;
      allow write: if isAdmin() || isTenantStaff('pilar') || isPlatformAdmin();
    }
  }
}
